# ── CallLens — Docker Compose Environment ────────────────────────────
# Copy to .env before running: cp .env.example .env
# This file is used by docker-compose.yml for the full-stack local dev.

# ── Application ──────────────────────────────────────────────────────
# development: cookies not Secure-only (works over http), API docs enabled,
# no fail-loud on insecure defaults.
APP_ENV=development
APP_DEBUG=false

# ── Database ─────────────────────────────────────────────────────────
# Matches the postgres service in docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/calllens
DB_USE_PGBOUNCER=false

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────────────────────────
# Fine for local dev. In production, generate a real secret.
JWT_SECRET=docker-compose-dev-secret-not-for-production

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Storage ──────────────────────────────────────────────────────────
# The api and worker services share a Docker volume mounted at /data/storage.
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/data/storage

# ── Providers (all stub/offline — no API keys needed) ────────────────
TRANSCRIBER_PROVIDER=stub
DIARIZER_PROVIDER=null
LLM_PROVIDER=stub
EMBEDDING_PROVIDER=stub
REDACTION_PROVIDER=regex
TOPIC_EXTRACTOR=stub

# ── Demo seeding ─────────────────────────────────────────────────────
# Auto-seeds 16 demo calls on first boot so the dashboard isn't empty.
SEED_DEMO_ON_START=true

# ── Concurrency ──────────────────────────────────────────────────────
WEB_CONCURRENCY=1
CELERY_CONCURRENCY=1

# ── Frontend ─────────────────────────────────────────────────────────
BACKEND_URL=http://api:8000

# ── To enable real providers, uncomment and add your keys: ───────────
# TRANSCRIBER_PROVIDER=assemblyai
# ASSEMBLYAI_API_KEY=your-key
# LLM_PROVIDER=langchain
# GOOGLE_API_KEY=your-key
# STORAGE_BACKEND=s3
# S3_BUCKET=calllens-audio
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_ENDPOINT_URL=            # for R2/B2/MinIO
