# Application
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://calllens:calllens@localhost:5432/calllens

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=CHANGE-ME-IN-PRODUCTION-use-a-random-32-plus-byte-secret
JWT_ACCESS_EXPIRY_SECONDS=900      # 15 minutes
JWT_REFRESH_EXPIRY_SECONDS=604800  # 7 days

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/tmp/calllens/audio
MAX_UPLOAD_MB=200

# Transcription providers (stub/faster_whisper/groq)
TRANSCRIBER_PROVIDER=stub
# Diarization providers (null/pyannote)
DIARIZER_PROVIDER=null
# Required when DIARIZER_PROVIDER=pyannote — accept model terms at
# https://huggingface.co/pyannote/speaker-diarization-3.1 first
HUGGINGFACE_TOKEN=
# Required when TRANSCRIBER_PROVIDER=groq
GROQ_API_KEY=

# LLM / agents (stub requires no keys; set to langchain to enable AI scoring)
# LLM_PROVIDER=stub
# GOOGLE_API_KEY=
# GROQ_API_KEY=
# LLM_MODEL_GOOGLE=gemini-1.5-flash
# LLM_MODEL_GROQ=llama3-70b-8192

# Embeddings (stub requires no deps; local needs calllens[embeddings]; gemini uses GOOGLE_API_KEY)
# NOTE: EMBEDDING_DIM is baked into the pgvector column; changing it requires a re-embed + migration.
# EMBEDDING_PROVIDER=stub
# EMBEDDING_DIM=384
# EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# Redaction (regex needs no deps; presidio needs calllens[redaction] + spaCy model)
# REDACTION_ENABLED=true
# REDACTION_PROVIDER=regex
# REDACT_BEFORE_SCORING=true

# Topic extraction (stub needs no deps; llm uses the configured LLM provider)
# TOPIC_EXTRACTOR=stub
# TOPIC_RELEVANCE_THRESHOLD=0.1

# Score bands (calls ≥ GOOD are green, ≥ FAIR are amber, below FAIR are red)
# SCORE_BAND_GOOD=80
# SCORE_BAND_FAIR=60
