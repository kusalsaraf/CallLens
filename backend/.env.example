# ── CallLens Backend — Environment Variables ──────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# ── Application ──────────────────────────────────────────────────────
# Values: development | staging | production
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://calllens:calllens@localhost:5432/calllens
# Set to true when DATABASE_URL points at a transaction-mode pooler
# (e.g. Supabase port 6543, PgBouncer). Disables asyncpg prepared-statement
# caching so connections work correctly through the pooler.
DB_USE_PGBOUNCER=false

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT (REQUIRED in production — app refuses to start with defaults) ─
JWT_SECRET=CHANGE-ME-IN-PRODUCTION-use-a-random-32-plus-byte-secret
# Access token lifetime in seconds (default 900 = 15 minutes)
JWT_ACCESS_EXPIRY_SECONDS=900
# Refresh token lifetime in seconds (default 604800 = 7 days)
JWT_REFRESH_EXPIRY_SECONDS=604800

# ── CORS (JSON array of allowed origins) ─────────────────────────────
# In production, set to your frontend origin only (no wildcard).
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Storage (local or s3) ───────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/tmp/calllens/audio
MAX_UPLOAD_MB=200

# S3-compatible storage (required when STORAGE_BACKEND=s3)
# Works with AWS S3, Cloudflare R2, Backblaze B2, MinIO, Supabase Storage.
# S3_BUCKET=calllens-audio
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=

# ── Transcription providers (stub/faster_whisper/groq/assemblyai) ───
TRANSCRIBER_PROVIDER=stub
# Diarization providers (null/pyannote/passthrough)
# When TRANSCRIBER_PROVIDER=assemblyai, diarizer is auto-set to passthrough.
DIARIZER_PROVIDER=null
HUGGINGFACE_TOKEN=
GROQ_API_KEY=
ASSEMBLYAI_API_KEY=

# ── LLM / agents ────────────────────────────────────────────────────
# LLM_PROVIDER=stub
# GOOGLE_API_KEY=
# LLM_MODEL_GOOGLE=gemini-1.5-flash
# LLM_MODEL_GROQ=llama3-70b-8192

# ── Embeddings ───────────────────────────────────────────────────────
# EMBEDDING_PROVIDER=stub
# EMBEDDING_DIM=384
# EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# ── Redaction ────────────────────────────────────────────────────────
# REDACTION_ENABLED=true
# REDACTION_PROVIDER=regex
# REDACT_BEFORE_SCORING=true

# ── Topic extraction ────────────────────────────────────────────────
# TOPIC_EXTRACTOR=stub
# TOPIC_RELEVANCE_THRESHOLD=0.1

# ── Score bands ──────────────────────────────────────────────────────
# SCORE_BAND_GOOD=80
# SCORE_BAND_FAIR=60

# ── API docs gating ─────────────────────────────────────────────────
# By default: enabled in dev/staging, disabled in production.
# Override: ENABLE_API_DOCS=true to force-enable even in production.
# ENABLE_API_DOCS=

# ── Demo seeding on start ───────────────────────────────────────────
# When true AND no demo data exists, auto-runs the demo seeder (--no-audio)
# after migrations during app startup. Off by default.
SEED_DEMO_ON_START=false

# ── Auth rate limiting ──────────────────────────────────────────────
# Max auth requests per IP per minute (login/signup/refresh).
# In-memory; sufficient for single-instance deploys.
# AUTH_RATE_LIMIT_PER_MINUTE=20
