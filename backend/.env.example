# Application
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://calllens:calllens@localhost:5432/calllens

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=CHANGE-ME-IN-PRODUCTION-use-a-random-32-plus-byte-secret
JWT_ACCESS_EXPIRY_SECONDS=900      # 15 minutes
JWT_REFRESH_EXPIRY_SECONDS=604800  # 7 days

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Storage
STORAGE_BACKEND=local
