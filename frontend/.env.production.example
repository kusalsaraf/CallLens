# ── CallLens Frontend — Production Environment Variables ─────────────
#
# Copy this file to .env.production.local and fill in real values.
# On Vercel, set these in the project's Environment Variables UI.

# Backend API URL — the Next.js rewrite proxies /api/* to this origin.
# This keeps the httpOnly refresh cookie first-party (same-origin) so
# SameSite=Lax works without SameSite=None.
#
# Example for Render: https://calllens-api.onrender.com
# Example for Railway: https://calllens-api.up.railway.app
BACKEND_URL=https://your-backend-api.example.com
